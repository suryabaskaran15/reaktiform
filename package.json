{
  "name": "reaktiform",
  "version": "1.0.2",
  "description": "Inline editable data grid with built-in form for React — table + form unified",
  "author": "Surya Baskaran",
  "license": "MIT",
  "keywords": [
    "react",
    "table",
    "form",
    "datagrid",
    "tanstack",
    "inline-edit",
    "crud",
    "data-table",
    "react-table",
    "editable-grid",
    "tanstack-table"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suryabaskaran15/reaktiform.git"
  },
  "homepage": "https://github.com/suryabaskaran15/reaktiform#readme",
  "bugs": {
    "url": "https://github.com/suryabaskaran15/reaktiform/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./headless": {
      "import": "./dist/headless.js",
      "require": "./dist/headless.cjs",
      "types": "./dist/headless.d.ts"
    },
    "./styles": "./dist/reaktiform.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "prepublishOnly": "pnpm build && pnpm type-check",
    "release": "pnpm build && npm publish --access public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.5",
    "immer": "^10.1.1",
    "lucide-react": "^0.483.0",
    "react-hook-form": "^7.55.0",
    "zod": "^3.24.2",
    "@hookform/resolvers": "^3.10.0",
    "zustand": "^5.0.3",
    "react-select": "^5.8.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.13.14",
    "@storybook/react": "^8.6.9",
    "@storybook/react-vite": "^8.6.9",
    "@storybook/addon-essentials": "^8.6.9",
    "@storybook/addon-interactions": "^8.6.9",
    "@storybook/addon-a11y": "^8.6.9",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "storybook": "^8.6.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.1.1",
    "tailwindcss": "^4.0.15",
    "@tailwindcss/vite": "^4.0.15",
    "@tailwindcss/cli": "^4.0.15"
  },
  "style": "./dist/reaktiform.css"
}
