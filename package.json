{
  "name": "reaktiform",
  "version": "1.2.1",
  "description": "High-performance inline-editable data grid for React — table + form unified. Full UI or headless, server-side or client-side.",
  "author": "Surya Baskaran",
  "license": "MIT",
  "keywords": [
    "react",
    "table",
    "datagrid",
    "data-grid",
    "data-table",
    "inline-edit",
    "editable-grid",
    "crud",
    "form",
    "tanstack",
    "react-table",
    "virtualized",
    "spreadsheet",
    "headless",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suryabaskaran15/reaktiform.git"
  },
  "homepage": "https://github.com/suryabaskaran15/reaktiform#readme",
  "bugs": {
    "url": "https://github.com/suryabaskaran15/reaktiform/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/reaktiform.css",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./headless": {
      "import": "./dist/headless.mjs",
      "require": "./dist/headless.js",
      "types": "./dist/headless.d.ts"
    },
    "./cells": {
      "import": "./dist/cells.mjs",
      "require": "./dist/cells.js",
      "types": "./dist/cells.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives.mjs",
      "require": "./dist/primitives.js",
      "types": "./dist/primitives.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./styles": {
      "import": "./dist/reaktiform.css",
      "require": "./dist/reaktiform.css",
      "types": "./dist-types/reaktiform.css.d.ts"
    },
    "./cells/styles": {
      "import": "./dist/cells.css",
      "require": "./dist/cells.css",
      "types": "./dist-types/cells.css.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "dist-types"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "prepublishOnly": "pnpm build && pnpm type-check",
    "release": "pnpm build && npm publish --access public",
    "size": "size-limit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.5",
    "immer": "^10.1.1",
    "lucide-react": "^0.483.0",
    "react-hook-form": "^7.55.0",
    "zod": "^3.24.2",
    "@hookform/resolvers": "^3.10.0",
    "zustand": "^5.0.3",
    "react-select": "^5.8.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.13.14",
    "@storybook/react": "^8.6.9",
    "@storybook/react-vite": "^8.6.9",
    "@storybook/addon-essentials": "^8.6.9",
    "@storybook/addon-interactions": "^8.6.9",
    "@storybook/addon-a11y": "^8.6.9",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "storybook": "^8.6.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.1.1",
    "tailwindcss": "^4.0.15",
    "@tailwindcss/vite": "^4.0.15",
    "@tailwindcss/cli": "^4.0.15"
  },
  "typesVersions": {
    "*": {
      "styles": [
        "./dist-types/reaktiform.css.d.ts"
      ],
      "cells/styles": [
        "./dist-types/cells.css.d.ts"
      ],
      "headless": [
        "./dist/headless.d.ts"
      ],
      "cells": [
        "./dist/cells.d.ts"
      ],
      "primitives": [
        "./dist/primitives.d.ts"
      ],
      "utils": [
        "./dist/utils.d.ts"
      ]
    }
  }
}
